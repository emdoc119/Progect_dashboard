# Dashboard bind address. Default: 127.0.0.1 (loopback only)
DASHBOARD_HOST=127.0.0.1

# Dashboard port. Default: 3001
DASHBOARD_PORT=3001

# Basic Auth credentials. REQUIRED when DASHBOARD_ALLOW_LAN=true.
# Use strong, unique values — the server will refuse to start
# on an external interface without these.
DASHBOARD_AUTH_USERNAME=
DASHBOARD_AUTH_PASSWORD=

# Set to true to bind to 0.0.0.0 for Tailscale/LAN access.
# Authentication credentials above become mandatory.
DASHBOARD_ALLOW_LAN=false

# Set to false to start the dashboard without launching always_on projects.
# Useful for testing and maintenance.
DASHBOARD_AUTOSTART=true

# Telegram crash notifications (optional)
# Get a bot token from @BotFather on Telegram
# Get your chat ID from @userinfobot or by sending a message to the bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
